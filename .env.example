# =============================================================
# ft_transcendence - Environment Variables Template
# Kopyala: cp .env.example .env
# Sonra tüm değerleri doldur.
# =============================================================

# ─────────────────────────────────────────────
# GENEL
# ─────────────────────────────────────────────
NODE_ENV=production
CORS_ORIGIN=https://localhost

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
# openssl rand -base64 64 ile üret
JWT_SECRET=CHANGE_ME_SUPER_SECRET_KEY
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─────────────────────────────────────────────
# 42 OAUTH
# https://profile.intra.42.fr/oauth/applications
# ─────────────────────────────────────────────
FORTYTWO_CLIENT_ID=
FORTYTWO_CLIENT_SECRET=
FORTYTWO_CALLBACK_URL=https://localhost/api/oauth/42/callback

# ─────────────────────────────────────────────
# GOOGLE OAUTH
# https://console.cloud.google.com/
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://localhost/api/oauth/google/callback

# ─────────────────────────────────────────────
# GITHUB OAUTH
# https://github.com/settings/developers
# ─────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://localhost/api/oauth/github/callback

# ─────────────────────────────────────────────
# SMTP (E-posta / 2FA)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ft-transcendence.local

# ─────────────────────────────────────────────
# UPLOAD AYARLARI
# ─────────────────────────────────────────────
MAX_FILE_SIZE=5242880
BCRYPT_SALT_ROUNDS=12

# ─────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ─────────────────────────────────────────────
# ELK STACK
# ─────────────────────────────────────────────
# Elasticsearch elastic kullanıcı şifresi
ELASTIC_PASSWORD=changeme_elastic_password
# Kibana sistem şifresi
KIBANA_PASSWORD=changeme_kibana_password

# ─────────────────────────────────────────────
# GRAFANA
# ─────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme_grafana_password
