{
  "name": "ft_transcendence_frontend",
  "version": "1.0.0",
  "description": "Frontend for ft_transcendence project - TypeScript + Tailwind CSS SPA",
  "main": "index.js",
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "start": "npm run build && npm run serve",
    "serve": "http-server dist -p 5173 --ssl --cert certs/cert.pem --key certs/key.pem -P https://localhost:5173?"
  },
  "keywords": [
    "transcendence",
    "pong",
    "typescript",
    "spa",
    "tailwindcss"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^20.19.31",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "autoprefixer": "^10.4.16",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^6.8.1",
    "eslint": "^8.45.0",
    "html-webpack-plugin": "^5.5.3",
    "http-server": "^14.1.1",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss": "^8.4.31",
    "postcss-loader": "^7.3.3",
    "style-loader": "^3.3.3",
    "tailwindcss": "^3.3.5",
    "ts-loader": "^9.4.4",
    "typescript": "^5.1.6",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "dependencies": {
    "@babylonjs/core": "^8.51.2",
    "@babylonjs/loaders": "^8.51.2",
    "axios": "^1.4.0",
    "chart.js": "^4.5.1"
  }
}
