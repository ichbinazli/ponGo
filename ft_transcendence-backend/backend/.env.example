# ===========================================
# ft_transcendence Backend Environment Config
# ===========================================

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Database
DATABASE_PATH=./database/transcendence.db

# JWT Configuration
JWT_SECRET=benim-gizli-anahtarim-cok-uzun-olmali-12345678
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OAuth 2.0 - 42 Intra
FORTYTWO_CLIENT_ID=your-42-client-id
FORTYTWO_CLIENT_SECRET=your-42-client-secret
FORTYTWO_CALLBACK_URL=https://localhost:3000/api/oauth/42/callback

# 2FA Configuration
TWO_FACTOR_APP_NAME=ft_transcendence
TWO_FACTOR_ISSUER=ft_transcendence

# HTTPS/SSL Configuration
SSL_KEY_PATH=./certs/key.pem
SSL_CERT_PATH=./certs/cert.pem

# CORS Configuration
CORS_ORIGIN=https://localhost:5173

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Bcrypt
BCRYPT_SALT_ROUNDS=12
