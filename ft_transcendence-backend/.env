# ===========================================
# ft_transcendence Environment Config
# ===========================================
# Copy this file to .env and fill in the values

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# JWT Configuration (CHANGE THIS IN PRODUCTION!)
JWT_SECRET=change-this-to-a-very-long-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OAuth 2.0 - Google (Get from Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://localhost:3000/api/auth/google/callback

# OAuth 2.0 - GitHub (Get from GitHub Developer Settings)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://localhost:3000/api/auth/github/callback

# 2FA Configuration
TWO_FACTOR_APP_NAME=ft_transcendence

# CORS (Frontend URL)
CORS_ORIGIN=https://localhost:5173

# Bcrypt Salt Rounds
BCRYPT_SALT_ROUNDS=12
